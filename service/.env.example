# Copy this to .env and fill in real values. .env is gitignored.

# ── Required ────────────────────────────────────────────────────────────────
# Anthropic API key (also pays for the agent's web_search / web_fetch usage).
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── Auth (fail-CLOSED in production) ────────────────────────────────────────
# In production (AUDITOR_FAIL_CLOSED=1 or a Railway env signal) the service
# REFUSES internal/enumeration/expensive routes unless these are set.
AUDIT_USERNAME=admin
AUDIT_PASSWORD=change-me
AUDIT_API_KEY=some-long-random-key        # server-to-server (X-API-Key header)
AUDITOR_FAIL_CLOSED=1                      # force fail-closed even off Railway

# ── Scoring / cost guardrails ───────────────────────────────────────────────
AUDIT_MODE=agent                          # agent | deterministic | auto
MAX_AUDIT_COST_USD=2.50                    # abort an audit past this est. spend
MAX_CONCURRENT_AUDITS=3
MAX_AUDIT_SECONDS=1200

# ── Persistence (durable jobs + report reload) ──────────────────────────────
# Supabase REST. Enables audit persistence, redeploy-safe report links,
# metering, and the delta loop. Service-role key bypasses RLS — keep it secret.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Webhooks (signed callbacks) ─────────────────────────────────────────────
AUDIT_WEBHOOK_SECRET=another-long-random-secret   # HMAC-SHA256 signing key
WEBHOOK_MAX_ATTEMPTS=3

# ── Billing / metering (optional) ───────────────────────────────────────────
BILLING_ENABLED=0                         # 1 to enforce per-key quota
FREE_MONTHLY_QUOTA=50
STRIPE_SECRET_KEY=                        # sk_live_... to enable usage reporting
STRIPE_METER_EVENT=audit_run

# ── Domain suppression (takedowns) ──────────────────────────────────────────
SUPPRESSED_DOMAINS=                        # comma-separated, durable across redeploys

# ── Misc ────────────────────────────────────────────────────────────────────
AUDIT_OUTPUT_DIR=./audits
CHROME_PATH=/usr/bin/chromium              # PDF renderer (Linux/Railway)
PORT=8000
LOG_LEVEL=INFO
